---
// willaicite landing page: static, self-contained, zero external resources
// at render time. Visual language shared with the audit app (public/index.html
// in the tool repo): warm paper, warm ink, one vermilion accent, serif display
// + mono data. External links below are citations; each was verified live.
import Base, { UPDATED_ISO } from '../layouts/Base.astro';

const TITLE = 'willaicite · SEO gets you listed, GEO gets you quoted';
const DESCRIPTION =
  'willaicite is a free, deterministic audit that scores whether AI answer engines (ChatGPT, Perplexity, Google AI Overviews and Claude) can retrieve your page, extract it without JavaScript, and cite it. No LLM calls, no fabricated numbers.';

const dimensions = [
  { name: 'AI crawler access', weight: 'high', note: 'Can the engines that cite pages fetch this one at all: per crawler token, robots.txt and firewall both.' },
  { name: 'Renderability', weight: 'high', note: 'How much of the content survives in raw HTML, with no JavaScript executed.' },
  { name: 'Answer-readiness', weight: 'high', note: 'Is there a self-contained, liftable answer near the top, under question-shaped headings.' },
  { name: 'Evidence density', weight: 'high', note: 'The material engines prefer to quote: statistics, quotations and cited sources.' },
  { name: 'Structured data', weight: 'medium', note: 'Schema.org markup that helps Google AI Overviews and entity trust.' },
  { name: 'Freshness', weight: 'medium', note: 'Visible and machine-readable dates; engines discount the undatable.' },
  { name: 'Entity & E-E-A-T', weight: 'medium', note: 'A nameable author, organization and provenance an engine can attribute.' },
];

// FAQ is single-sourced: this array renders the visible section AND the
// FAQPage JSON-LD, so the markup can never disagree with the page.
const faqs = [
  {
    q: 'How is GEO different from SEO?',
    a: 'SEO answers the question “where do we rank in the list of links?” GEO answers the question “does the synthesized answer quote us?” The two overlap less than you would hope: an answer engine must fetch your page with its own crawler, extract it without running JavaScript, and find a passage worth quoting verbatim. Three steps, and no ranking audit tests them.',
  },
  {
    q: 'Does blocking GPTBot stop ChatGPT from citing my page?',
    a: 'No. GPTBot is OpenAI’s training crawler; retrieval for ChatGPT search runs through OAI-SearchBot and ChatGPT-User. Blocking GPTBot is a legitimate policy choice about model training. Blocking OAI-SearchBot removes you from ChatGPT’s citations entirely. willaicite reports each token separately so you can tell the two decisions apart.',
  },
  {
    q: 'Why does my JavaScript-rendered site score low?',
    a: 'AI crawlers read the raw HTML your server sends and do not execute JavaScript. If your content only exists after a framework boots in the browser, those crawlers see an empty shell. Server-render or prerender everything you want an engine to be able to quote.',
  },
  {
    q: 'How fresh does my content need to be?',
    a: 'Answer engines cite pages updated within the last 90 days far more readily; reported citation likelihood drops off sharply past roughly 3 months. Keep a visible and machine-readable date, and bump it only with genuine edits; willaicite reads both and flags undatable pages.',
  },
  {
    q: 'Does willaicite check SEO too?',
    a: 'No. willaicite audits the citation path, which is GEO. Several of the signals it checks (crawler access, structured data, visible dates, clear headings, authorship) are SEO fundamentals as well, so fixes often help both. But it does not measure rankings, keywords, backlinks or page speed; established SEO tools already cover that ground.',
  },
  {
    q: 'What does an audit cost, and what happens to my data?',
    a: 'Nothing; willaicite is free. An audit makes at most ten requests to your site and typically finishes in under 30 seconds. It is deterministic: no LLM calls, no sampling.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://willaicite.com/#org',
      name: 'willaicite',
      url: 'https://willaicite.com/',
      logo: 'https://willaicite.com/favicon.svg',
      sameAs: ['https://github.com/ryanportfolio'],
    },
    {
      '@type': 'Person',
      '@id': 'https://willaicite.com/#ryan',
      name: 'Ryan',
      url: 'https://github.com/ryanportfolio',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://willaicite.com/#site',
      name: 'willaicite',
      url: 'https://willaicite.com/',
      publisher: { '@id': 'https://willaicite.com/#org' },
    },
    {
      '@type': 'TechArticle',
      '@id': 'https://willaicite.com/#article',
      headline: 'SEO gets you listed, GEO gets you quoted',
      description: DESCRIPTION,
      author: { '@id': 'https://willaicite.com/#ryan' },
      publisher: { '@id': 'https://willaicite.com/#org' },
      datePublished: UPDATED_ISO,
      dateModified: UPDATED_ISO,
      mainEntityOfPage: 'https://willaicite.com/',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://willaicite.com/#faq',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://willaicite.com/#crumbs',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'willaicite', item: 'https://willaicite.com/' },
        { '@type': 'ListItem', position: 2, name: 'About', item: 'https://willaicite.com/about' },
      ],
    },
  ],
};
---
<Base title={TITLE} description={DESCRIPTION} canonical="https://willaicite.com/" schema={schema}>

<main>
  <div class="sheet">
    <!-- ================= hero ================= -->
    <section class="hero" aria-labelledby="hero-h">
      <h1 id="hero-h">SEO gets you listed<br /><em>GEO gets you quoted</em></h1>
      <p class="sub">
        willaicite is a free, deterministic audit that scores whether AI answer engines
        (ChatGPT, Perplexity, Google AI Overviews and Claude) can retrieve your page, extract
        it without running your JavaScript, and quote it inside a synthesized answer.
      </p>
      <p class="takeaway">
        <span class="t1">Search engines rank you in a list of links;</span>
        <span class="t2">answer engines quote you.</span>
        <span class="t3"><span class="tw">will<span class="ai">ai</span>cite</span> measures whether they can.</span>
      </p>
      <form class="run" action="/app" method="get">
        <label class="visually-hidden" for="url">Your page URL</label>
        <input id="url" name="url" type="text" placeholder="yoursite.com/your-best-page" autocomplete="off" spellcheck="false" />
        <button type="submit">Audit</button>
      </form>
      <p class="fineprint">free &middot; deterministic &middot; results in about 30 seconds</p>

      <figure class="answerfig">
        <div class="answercard" aria-hidden="true">
          <div class="q">“how long does waxed canvas stay waterproof?”</div>
          <div class="a">
            Wax impregnation remains the most durable treatment.
            <mark>“A properly waxed canvas resists water for three to five seasons
            before re-treatment.”</mark><sup>[1]</sup> Re-waxing seams first extends&hellip;
          </div>
          <div class="cite"><span class="marker">[1]</span> yoursite.com/guides/canvas-care</div>
        </div>
      </figure>
    </section>

    <!-- ================= five differentiators ================= -->
    <section aria-labelledby="miss-h">
      <div class="report-rule"><h2 class="rulelabel" id="miss-h">What your SEO tool doesn&rsquo;t test</h2></div>
      <p class="section-intro">
        SEO tooling audits the path to a ranking. willaicite audits the path to a citation.
        Five places the two roads split.
      </p>

      <ol class="diffs">
        <li>
          <h3>The block robots.txt won&rsquo;t admit to</h3>
          <p>
            willaicite fetches your page twice, once as an ordinary browser and once wearing an
            AI crawler&rsquo;s user agent, then compares what comes back. A CDN firewall rule like
            Cloudflare&rsquo;s <a class="body-link" href="https://blog.cloudflare.com/declaring-your-aindependence-block-ai-bots-scrapers-and-crawlers-with-a-single-click/">one-click &ldquo;block AI bots&rdquo; toggle</a>
            returns 403 to the real crawler while robots.txt keeps saying <em>allowed</em>.
            SEO crawlers never walk the AI-bot path, so they report clean while the engine
            silently drops your page.
          </p>
          <figure class="minifig">
            <table class="ledger">
              <thead class="visually-hidden"><tr><th>check</th><th>result</th><th>meaning</th></tr></thead>
              <tbody>
                <tr><td class="k">robots.txt, GPTBot</td><td class="ok">allowed</td><td class="c">what every SEO tool reads</td></tr>
                <tr><td class="k">fetch, browser UA</td><td class="ok">200 OK</td><td class="c">what your monitoring sees</td></tr>
                <tr><td class="k">fetch, GPTBot UA</td><td class="bad">403 Forbidden</td><td class="c">what the engine actually gets</td></tr>
              </tbody>
            </table>
          </figure>
        </li>

        <li>
          <h3>The single-page app nobody&rsquo;s reading</h3>
          <p>
            <a class="body-link" href="https://developers.google.com/search/docs/crawling-indexing/javascript/javascript-seo-basics">Googlebot renders JavaScript</a>;
            so does Lighthouse. GPTBot, ClaudeBot and PerplexityBot do not; they see whatever
            the server sends and nothing more. A client-rendered page audits perfectly and
            arrives at the answer engine as an empty shell. willaicite scores how much of your
            content survives in the raw HTML, from the exact no-JavaScript vantage those
            crawlers have.
          </p>
          <figure class="minifig split">
            <div class="pane">
              <div class="pane-label">browser &middot; JS executed</div>
              <div class="pane-body prose-demo">
                <span class="line w90"></span><span class="line w100"></span>
                <span class="line w75"></span><span class="line w95"></span>
                <span class="line w60"></span>
              </div>
            </div>
            <div class="pane">
              <div class="pane-label">AI crawler &middot; raw HTML</div>
              <div class="pane-body"><code>&lt;div id="root"&gt;&lt;/div&gt;</code></div>
            </div>
          </figure>
        </li>

        <li>
          <h3>The outbound-citation inversion</h3>
          <p>
            Classic SEO folklore says external links leak PageRank, so pages hoard authority and
            cite no one. The <a class="body-link" href="https://arxiv.org/abs/2311.09735">GEO study</a>
            (Aggarwal et&nbsp;al., KDD&nbsp;2024) measured the opposite effect on AI visibility:
            citing sources lifted it 24.9 percent, statistics 25.9 percent, and quotations
            27.8 percent. One benchmark, directional rather than guaranteed. But it means
            optimizing for the ranking can quietly cost you the quote.
          </p>
          <figure class="minifig">
            <div class="stats">
              <div class="stat"><span class="stat-k">citing sources</span><span class="stat-bar"><i style="--w:89%"></i></span><span class="stat-v">+24.9%</span></div>
              <div class="stat"><span class="stat-k">statistics</span><span class="stat-bar"><i style="--w:93%"></i></span><span class="stat-v">+25.9%</span></div>
              <div class="stat"><span class="stat-k">quotations</span><span class="stat-bar"><i style="--w:100%"></i></span><span class="stat-v">+27.8%</span></div>
            </div>
            <figcaption>Visibility lift in generative answers (Aggarwal et&nbsp;al., <cite>GEO: Generative Engine Optimization</cite>, KDD&nbsp;2024). One study; directional, not a guarantee.</figcaption>
          </figure>
        </li>

        <li>
          <h3>A verdict per engine, weighed by what it costs you</h3>
          <p>
            &ldquo;Is Googlebot allowed&rdquo; is one question. willaicite asks it for a roster of AI crawler
            tokens and separates <em>retrieval</em> crawlers, where a block means that engine can never
            cite you, from <em>training-only</em> tokens, where blocking is a legitimate policy choice
            rather than a citation problem. The <a class="body-link" href="/crawlers">full registry</a>
            documents every token willaicite checks.
          </p>
          <figure class="minifig">
            <table class="ledger roster">
              <thead class="visually-hidden"><tr><th>crawler token</th><th>tier</th><th>consequence when blocked</th></tr></thead>
              <tbody>
                <tr><td class="k"><a href="https://developers.openai.com/api/docs/bots">OAI-SearchBot</a></td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; ChatGPT can never cite you</td></tr>
                <tr><td class="k"><a href="https://support.claude.com/en/articles/8896518-does-anthropic-crawl-data-from-the-web-and-how-can-site-owners-block-the-crawler">Claude-SearchBot</a></td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; Claude can never cite you</td></tr>
                <tr><td class="k"><a href="https://docs.perplexity.ai/guides/bots">PerplexityBot</a></td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; Perplexity can never cite you</td></tr>
                <tr><td class="k">GPTBot &middot; ClaudeBot &middot; CCBot</td><td class="tier">training</td><td class="c">blocking is a policy choice, not a citation bug</td></tr>
              </tbody>
            </table>
          </figure>
        </li>

        <li>
          <h3>Is there a liftable answer?</h3>
          <p>
            Engines quote a chunk, verbatim. willaicite checks whether one exists: a self-contained
            answer near the top of the page, headings phrased as the questions people actually ask,
            an FAQ ready to be lifted whole. A page that opens with a sentence like
            <q>willaicite is a free audit that scores citation readiness</q> hands the engine its
            quote; a page that opens with a hero animation hands it nothing. You can rank first
            for a query and still contain nothing an engine can use.
          </p>
          <figure class="minifig">
            <ul class="checks">
              <li><span class="g pass">&check;</span>self-contained definition in the first screenful: &ldquo;X is &hellip;&rdquo;</li>
              <li><span class="g pass">&check;</span>headings phrased as questions users ask</li>
              <li><span class="g fail">&#10007;</span>no FAQ: nothing an engine can lift whole</li>
            </ul>
          </figure>
        </li>
      </ol>
    </section>

    <!-- ================= seven dimensions ================= -->
    <section aria-labelledby="dims-h">
      <div class="report-rule"><h2 class="rulelabel" id="dims-h">The seven dimensions</h2></div>
      <p class="section-intro">
        Every audit scores the same seven dimensions, weighted by how often each one decides
        whether a citation happens.
      </p>
      <ol class="dims">
        {dimensions.map((d, i) => (
          <li>
            <span class="dimno">{String(i + 1).padStart(2, '0')}</span>
            <span class="dimname">{d.name}</span>
            <span class="dimweight">wt {d.weight}</span>
            <span class="dimnote">{d.note}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- ================= FAQ ================= -->
    <section aria-labelledby="faq-h">
      <div class="report-rule"><h2 class="rulelabel" id="faq-h">Frequently asked questions</h2></div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- ================= method band (full bleed, inverted) ================= -->
  <section class="band" aria-labelledby="method-h">
    <div class="band-inner">
      <div class="band-rule"><h2 class="rulelabel" id="method-h">Method</h2></div>
      <p class="band-head">How the score is made</p>
      <p>
        willaicite is deterministic: no LLM calls, no sampling, and every point is tied to
        evidence you can check in the report. An audit makes at most ten polite requests to
        your site (your page twice, robots.txt, the sitemap and a few supporting files) and
        honors robots.txt, while telling you what robots.txt won&rsquo;t.
      </p>
      <a class="cta inverted" href="/app">Audit your site</a>
    </div>
  </section>
</main>

<script>
  // Grow the stat bars when they scroll into view. Motion stands down under
  // prefers-reduced-motion (bars render at full width immediately).
  const bars = document.querySelectorAll<HTMLElement>('.stat-bar i');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || !('IntersectionObserver' in window)) {
    bars.forEach((b) => b.classList.add('grown'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('grown');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.4 },
    );
    bars.forEach((b) => io.observe(b));
  }
</script>

<style is:global>
  /* ---------- hero ---------- */
  .hero { padding: 72px 0 24px; }
  .hero h1 {
    font-size: clamp(38px, 7vw, 64px);
    font-weight: 500; line-height: 1.06; letter-spacing: -0.015em;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero .sub { margin-top: 22px; max-width: 62ch; color: var(--ink-soft); font-size: 17px; }
  /* the takeaway: a three-line stanza echoing the h1's roman-then-italic turn */
  .hero .takeaway {
    margin-top: 30px; max-width: 62ch;
    font-size: 21px; line-height: 1.4; letter-spacing: -0.01em;
  }
  .hero .takeaway > span { display: block; }
  .hero .takeaway .t1 { color: var(--ink-soft); }
  .hero .takeaway .t2 { font-style: italic; color: var(--accent); }
  .hero .takeaway .t3 { color: var(--ink); margin-top: 10px; }
  .hero .takeaway .tw { font-family: var(--mono); font-size: 0.82em; font-weight: 600; letter-spacing: 0.04em; }
  .hero .takeaway .tw .ai { color: var(--accent); }
  @media (max-width: 760px) {
    .hero .takeaway { font-size: 19px; }
  }

  /* the audit form IS the primary CTA: oversized, one vermilion button */
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap;
  }
  .hero form.run {
    margin-top: 36px; display: flex; gap: 0; max-width: 680px;
    border: 2px solid var(--ink); background: var(--paper-raised);
  }
  .hero form.run input {
    flex: 1; min-width: 0; border: 0; outline: none; background: transparent;
    font-family: var(--mono); font-size: 17px; color: var(--ink);
    padding: 21px 20px;
  }
  .hero form.run input::placeholder { color: var(--ink-faint); }
  .hero form.run input:focus-visible { outline: none; }
  .hero form.run:focus-within { border-color: var(--accent); }
  .hero form.run button {
    border: 0; cursor: pointer; background: var(--accent); color: #fbf8f1;
    font-family: var(--mono); font-size: 16px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0 40px; transition: background 0.15s ease;
  }
  .hero form.run button:hover { background: var(--ink); }
  .hero .fineprint { margin-top: 14px; }

  /* answer figure */
  .answerfig { margin-top: 56px; }
  .answercard {
    border: 1px solid var(--rule); background: var(--paper-raised);
    padding: 20px 22px; max-width: 640px;
    font-family: var(--mono); font-size: 13.5px; line-height: 1.7; color: var(--ink-soft);
  }
  .answercard .q { color: var(--ink-faint); font-size: 12px; margin-bottom: 12px; }
  .answercard .a mark { background: var(--accent-soft); color: var(--ink); padding: 1px 3px; }
  .answercard sup { color: var(--accent); font-weight: 700; }
  .answercard .cite { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--rule); font-size: 12.5px; }
  .answercard .marker { color: var(--accent); font-weight: 700; }
  .answercard .arrow { color: var(--ink-faint); font-style: italic; }

  /* ---------- differentiators ---------- */
  .diffs { list-style: none; counter-reset: diff; margin-top: 12px; }
  .diffs > li {
    counter-increment: diff;
    border-top: 1px solid var(--rule); margin-top: 40px; padding-top: 28px;
    display: grid; grid-template-columns: 52px 1fr; column-gap: 8px;
  }
  .diffs > li::before {
    content: counter(diff, decimal-leading-zero);
    font-family: var(--mono); font-size: 13px; color: var(--accent); font-weight: 700; padding-top: 7px;
  }
  .diffs > li:first-child { border-top: 0; margin-top: 28px; padding-top: 0; }
  .diffs h3 { font-size: 24px; font-weight: 500; line-height: 1.25; letter-spacing: -0.01em; grid-column: 2; }
  .diffs p { grid-column: 2; margin-top: 12px; max-width: 66ch; color: var(--ink-soft); font-size: 16px; }
  .diffs q { quotes: "“" "”"; font-style: italic; }
  .minifig { grid-column: 2; margin-top: 20px; }
  .minifig figcaption { margin-top: 10px; font-family: var(--mono); font-size: 11px; color: var(--ink-faint); max-width: 60ch; line-height: 1.6; }

  /* evidence ledgers */
  .ledger { border-collapse: collapse; width: 100%; max-width: 640px; background: var(--paper-raised); border: 1px solid var(--rule); }
  .ledger td { font-family: var(--mono); font-size: 12.5px; padding: 9px 14px; border-top: 1px solid var(--rule); vertical-align: baseline; }
  .ledger tr:first-child td { border-top: 0; }
  .ledger .k { color: var(--ink); white-space: nowrap; }
  .ledger .k a { text-decoration-color: var(--rule); text-underline-offset: 3px; }
  .ledger .k a:hover { color: var(--accent); }
  .ledger .ok { color: var(--ok); font-weight: 600; white-space: nowrap; }
  .ledger .bad { color: var(--accent); font-weight: 700; white-space: nowrap; }
  .ledger .c { color: var(--ink-faint); width: 55%; }
  .roster .tier { font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); white-space: nowrap; }
  .roster .tier.hot { color: var(--accent); font-weight: 700; }

  /* split pane (SPA figure) */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 640px; }
  .pane { border: 1px solid var(--rule); background: var(--paper-raised); }
  .pane-label {
    font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-faint); padding: 8px 12px; border-bottom: 1px solid var(--rule);
  }
  .pane-body { padding: 14px 12px; min-height: 96px; }
  .pane-body code { font-family: var(--mono); font-size: 12.5px; color: var(--ink-faint); }
  .prose-demo { display: flex; flex-direction: column; gap: 8px; }
  .prose-demo .line { display: block; height: 7px; background: var(--rule); }
  .prose-demo .w100 { width: 100%; } .prose-demo .w95 { width: 95%; }
  .prose-demo .w90 { width: 90%; } .prose-demo .w75 { width: 75%; } .prose-demo .w60 { width: 60%; }

  /* stat bars */
  .stats { max-width: 640px; border: 1px solid var(--rule); background: var(--paper-raised); padding: 6px 14px; }
  .stat { display: grid; grid-template-columns: 120px 1fr 64px; gap: 14px; align-items: center; padding: 9px 0; }
  .stat + .stat { border-top: 1px solid var(--rule); }
  .stat-k { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
  .stat-bar { height: 7px; background: var(--rule); position: relative; overflow: hidden; }
  .stat-bar i {
    position: absolute; inset: 0 auto 0 0; width: 0; background: var(--accent);
    transition: width 0.9s var(--ease);
  }
  .stat-bar i.grown { width: var(--w); }
  .stat-v { font-family: var(--mono); font-size: 13px; font-weight: 700; text-align: right; }

  /* checks list */
  .checks { list-style: none; max-width: 640px; border: 1px solid var(--rule); background: var(--paper-raised); padding: 10px 14px; }
  .checks li {
    display: flex; gap: 10px; padding: 6px 0;
