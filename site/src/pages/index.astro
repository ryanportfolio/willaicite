---
// willaicite landing page — static, self-contained, zero external resources.
// Visual language shared with the audit app (public/index.html in the tool repo):
// warm paper, warm ink, one vermilion accent, serif display + mono data.

const dimensions = [
  { name: 'AI crawler access', weight: 'high', note: 'Can the engines that cite pages fetch this one at all — per crawler token, robots.txt and firewall both.' },
  { name: 'Renderability', weight: 'high', note: 'How much of the content survives in raw HTML, with no JavaScript executed.' },
  { name: 'Answer-readiness', weight: 'high', note: 'Is there a self-contained, liftable answer — near the top, under question-shaped headings.' },
  { name: 'Evidence density', weight: 'high', note: 'Statistics, quotations and cited sources — the material engines prefer to quote.' },
  { name: 'Structured data', weight: 'medium', note: 'Schema.org markup that helps Google AI Overviews and entity trust.' },
  { name: 'Freshness', weight: 'medium', note: 'Visible and machine-readable dates; engines discount the undatable.' },
  { name: 'Entity & E-E-A-T', weight: 'medium', note: 'A nameable author, organization and provenance an engine can attribute.' },
];
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="willaicite audits whether AI answer engines — ChatGPT, Perplexity, Google AI Overviews, Claude — can fetch, extract and cite your page. Deterministic, evidence-based, no fabricated numbers." />
  <title>willaicite — SEO gets you listed. GEO gets you quoted.</title>
</head>
<body>

<div class="sheet">
  <header class="masthead">
    <div class="wordmark">will<span class="ai">ai</span>cite</div>
    <div class="masthead-meta">generative engine optimization &middot; field notes</div>
  </header>

  <main>
    <!-- ================= hero ================= -->
    <section class="hero" aria-labelledby="hero-h">
      <h1 id="hero-h">SEO gets you listed.<br /><em>GEO gets you quoted.</em></h1>
      <p class="sub">
        Search engines rank your page in a list of links. Answer engines — ChatGPT, Perplexity,
        Google AI Overviews, Claude — fetch it, read whatever survives without your JavaScript,
        and quote the best-evidenced passage inside a synthesized answer.
        willaicite audits whether your page survives that pipeline.
      </p>
      <div class="cta-row">
        <a class="cta" href="https://willaicite.com">Audit your site</a>
        <span class="fineprint">free &middot; deterministic &middot; same input, same score</span>
      </div>

      <figure class="answerfig">
        <figcaption>Fig. 1 — the outcome under audit: a verbatim quote, with attribution, inside someone else&rsquo;s answer.</figcaption>
        <div class="answercard" aria-hidden="true">
          <div class="q">“how long does waxed canvas stay waterproof?”</div>
          <div class="a">
            Wax impregnation remains the most durable treatment.
            <mark>“A properly waxed canvas resists water for three to five seasons
            before re-treatment.”</mark><sup>[1]</sup> Re-waxing seams first extends&hellip;
          </div>
          <div class="cite"><span class="marker">[1]</span> yoursite.com/guides/canvas-care <span class="arrow">&larr; the citation</span></div>
        </div>
      </figure>
    </section>

    <!-- ================= five differentiators ================= -->
    <section aria-labelledby="miss-h">
      <div class="report-rule"><span id="miss-h">What your SEO tool doesn&rsquo;t test</span></div>
      <p class="section-intro">
        SEO tooling audits the path to a ranking. willaicite audits the path to a citation.
        Five places the two roads split.
      </p>

      <ol class="diffs">
        <li>
          <h2>The block robots.txt won&rsquo;t admit to</h2>
          <p>
            willaicite fetches your page twice — once as an ordinary browser, once wearing an
            AI crawler&rsquo;s user agent — and compares what comes back. A CDN firewall rule like
            Cloudflare&rsquo;s &ldquo;Block AI bots&rdquo; returns 403 to the real crawler while robots.txt
            keeps saying <em>allowed</em>. SEO crawlers never walk the AI-bot path, so they report
            clean while the engine silently drops your page.
          </p>
          <figure class="minifig">
            <table class="ledger">
              <tbody>
                <tr><td class="k">robots.txt, GPTBot</td><td class="ok">allowed</td><td class="c">what every SEO tool reads</td></tr>
                <tr><td class="k">fetch, browser UA</td><td class="ok">200 OK</td><td class="c">what your monitoring sees</td></tr>
                <tr><td class="k">fetch, GPTBot UA</td><td class="bad">403 Forbidden</td><td class="c">what the engine actually gets</td></tr>
              </tbody>
            </table>
          </figure>
        </li>

        <li>
          <h2>The single-page app nobody&rsquo;s reading</h2>
          <p>
            Googlebot executes JavaScript; so does Lighthouse. GPTBot, ClaudeBot and PerplexityBot
            do not — they see whatever the server sends and nothing more. A client-rendered page
            audits perfectly and arrives at the answer engine as an empty shell. willaicite scores
            how much of your content survives in the raw HTML, from the exact no-JavaScript vantage
            those crawlers have.
          </p>
          <figure class="minifig split">
            <div class="pane">
              <div class="pane-label">browser &middot; JS executed</div>
              <div class="pane-body prose-demo">
                <span class="line w90"></span><span class="line w100"></span>
                <span class="line w75"></span><span class="line w95"></span>
                <span class="line w60"></span>
              </div>
            </div>
            <div class="pane">
              <div class="pane-label">AI crawler &middot; raw HTML</div>
              <div class="pane-body"><code>&lt;div id="root"&gt;&lt;/div&gt;</code></div>
            </div>
          </figure>
        </li>

        <li>
          <h2>The outbound-citation inversion</h2>
          <p>
            Classic SEO folklore says external links leak PageRank, so pages hoard authority and
            cite no one. The GEO study measured the opposite effect on AI visibility: pages that
            cite sources, quote experts and carry statistics get retrieved and quoted more.
            Optimizing for the ranking can quietly cost you the quote.
          </p>
          <figure class="minifig">
            <div class="stats">
              <div class="stat"><span class="stat-k">citing sources</span><span class="stat-bar"><i style="--w:89%"></i></span><span class="stat-v">+24.9%</span></div>
              <div class="stat"><span class="stat-k">statistics</span><span class="stat-bar"><i style="--w:93%"></i></span><span class="stat-v">+25.9%</span></div>
              <div class="stat"><span class="stat-k">quotations</span><span class="stat-bar"><i style="--w:100%"></i></span><span class="stat-v">+27.8%</span></div>
            </div>
            <figcaption>Visibility lift in generative answers — Aggarwal et&nbsp;al., <cite>GEO: Generative Engine Optimization</cite>, KDD&nbsp;2024. One study; directional, not a guarantee.</figcaption>
          </figure>
        </li>

        <li>
          <h2>A verdict per engine, weighed by what it costs you</h2>
          <p>
            &ldquo;Is Googlebot allowed&rdquo; is one question. willaicite asks it for a roster of AI crawler
            tokens and separates <em>retrieval</em> crawlers — where a block means that engine can never
            cite you — from <em>training-only</em> tokens, where blocking is a legitimate policy choice
            rather than a citation problem.
          </p>
          <figure class="minifig">
            <table class="ledger roster">
              <tbody>
                <tr><td class="k">OAI-SearchBot</td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; ChatGPT can never cite you</td></tr>
                <tr><td class="k">Claude-SearchBot</td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; Claude can never cite you</td></tr>
                <tr><td class="k">PerplexityBot</td><td class="tier hot">retrieval</td><td class="c">blocked &rarr; Perplexity can never cite you</td></tr>
                <tr><td class="k">GPTBot &middot; ClaudeBot &middot; CCBot</td><td class="tier">training</td><td class="c">blocking is a policy choice, not a citation bug</td></tr>
              </tbody>
            </table>
          </figure>
        </li>

        <li>
          <h2>Is there a liftable answer?</h2>
          <p>
            Engines quote a chunk, verbatim. willaicite checks whether one exists: a self-contained
            answer near the top of the page (&ldquo;X is&nbsp;&hellip;&rdquo;), headings phrased as the questions
            people actually ask, an FAQ ready to be lifted whole. A page can rank first for a query
            and still contain nothing an engine can quote.
          </p>
          <figure class="minifig">
            <ul class="checks">
              <li><span class="g pass">&check;</span>self-contained definition in the first screenful — &ldquo;X is &hellip;&rdquo;</li>
              <li><span class="g pass">&check;</span>headings phrased as questions users ask</li>
              <li><span class="g fail">&#10007;</span>no FAQ — nothing an engine can lift whole</li>
            </ul>
          </figure>
        </li>
      </ol>
    </section>

    <!-- ================= seven dimensions ================= -->
    <section aria-labelledby="dims-h">
      <div class="report-rule"><span id="dims-h">The seven dimensions</span></div>
      <p class="section-intro">
        Every audit scores the same seven dimensions, weighted by how often each one decides
        whether a citation happens.
      </p>
      <ol class="dims">
        {dimensions.map((d, i) => (
          <li>
            <span class="dimno">{String(i + 1).padStart(2, '0')}</span>
            <span class="dimname">{d.name}</span>
            <span class="dimweight">wt {d.weight}</span>
            <span class="dimnote">{d.note}</span>
          </li>
        ))}
      </ol>
    </section>
  </main>
</div>

<!-- ================= method band (full bleed, inverted) ================= -->
<section class="band" aria-labelledby="method-h">
  <div class="band-inner">
    <div class="band-rule"><span id="method-h">Method</span></div>
    <h2>Scored like a ledger,<br />not a horoscope.</h2>
    <p>
      willaicite is deterministic. No LLM calls, no sampling, no drift — the same input produces
      the same score, and every point is tied to evidence you can check. When something cannot be
      observed, the report says <em>could not verify</em> instead of inventing a number. It fetches
      at most ten URLs, politely, and respects robots.txt — while telling you what robots.txt won&rsquo;t.
    </p>
    <a class="cta inverted" href="https://willaicite.com">Audit your site — willaicite.com</a>
  </div>
</section>

<div class="sheet">
  <footer class="colophon">
    <span>willaicite &middot; generative engine optimization</span>
    <span>evidence basis: Aggarwal et&nbsp;al., KDD&nbsp;2024</span>
  </footer>
</div>

<script>
  // Grow the stat bars when they scroll into view. Motion stands down under
  // prefers-reduced-motion (bars render at full width immediately).
  const bars = document.querySelectorAll<HTMLElement>('.stat-bar i');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || !('IntersectionObserver' in window)) {
    bars.forEach((b) => b.classList.add('grown'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('grown');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.4 },
    );
    bars.forEach((b) => io.observe(b));
  }
</script>

<style is:global>
  :root {
    --paper: #f4f0e6;
    --paper-raised: #fbf8f1;
    --ink: #1c1914;
    --ink-soft: #4a443a;
    --ink-faint: #8a8172;
    --rule: #d8d0bd;
    --accent: #cf3b1a;
    --accent-soft: #f3ddd4;
    --ok: #2c6e49;
    --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif;
    --mono: ui-monospace, "Cascadia Code", "SF Mono", Menlo, Consolas, monospace;
    --ease: cubic-bezier(0.22, 0.9, 0.35, 1);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --paper: #171511;
      --paper-raised: #201d17;
      --ink: #eae3d2;
      --ink-soft: #b5ac97;
      --ink-faint: #7d7563;
      --rule: #383327;
      --accent: #f05a35;
      --accent-soft: #3a2018;
      --ok: #6dbb8f;
    }
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
    background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(128,116,90,0.025) 3px, rgba(128,116,90,0.025) 4px);
  }
  .sheet { max-width: 880px; margin: 0 auto; padding: 0 28px; }
  a { color: inherit; }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* ---------- masthead ---------- */
  .masthead {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 22px 0 14px; border-bottom: 2px solid var(--ink);
  }
  .wordmark { font-family: var(--mono); font-size: 15px; font-weight: 600; letter-spacing: 0.04em; }
  .wordmark .ai { color: var(--accent); }
  .masthead-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.06em; text-transform: uppercase; }

  /* ---------- hero ---------- */
  .hero { padding: 72px 0 24px; }
  .hero h1 {
    font-size: clamp(38px, 7vw, 64px);
    font-weight: 500; line-height: 1.06; letter-spacing: -0.015em;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero .sub { margin-top: 22px; max-width: 60ch; color: var(--ink-soft); font-size: 17px; }
  .cta-row { margin-top: 34px; display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
  .cta {
    display: inline-block; background: var(--ink); color: var(--paper);
    font-family: var(--mono); font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;
    text-decoration: none; padding: 14px 28px; border: 1.5px solid var(--ink);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .cta:hover { background: var(--accent); border-color: var(--accent); }
  .fineprint { font-family: var(--mono); font-size: 11.5px; color: var(--ink-faint); }

  /* answer figure */
  .answerfig { margin-top: 56px; }
  .answerfig figcaption {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 10px;
  }
  .answercard {
    border: 1px solid var(--rule); background: var(--paper-raised);
    padding: 20px 22px; max-width: 640px;
    font-family: var(--mono); font-size: 13.5px; line-height: 1.7; color: var(--ink-soft);
  }
  .answercard .q { color: var(--ink-faint); font-size: 12px; margin-bottom: 12px; }
  .answercard .a mark { background: var(--accent-soft); color: var(--ink); padding: 1px 3px; }
  .answercard sup { color: var(--accent); font-weight: 700; }
  .answercard .cite { margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--rule); font-size: 12.5px; }
  .answercard .marker { color: var(--accent); font-weight: 700; }
  .answercard .arrow { color: var(--ink-faint); font-style: italic; }

  /* ---------- section chrome ---------- */
  .report-rule { margin-top: 72px; border-top: 2px solid var(--ink); position: relative; }
  .report-rule span {
    position: absolute; top: -11px; left: 0; background: var(--paper); padding-right: 14px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft);
  }
  .section-intro { margin-top: 34px; max-width: 60ch; color: var(--ink-soft); }

  /* ---------- differentiators ---------- */
  .diffs { list-style: none; counter-reset: diff; margin-top: 12px; }
  .diffs > li {
    counter-increment: diff;
    border-top: 1px solid var(--rule); margin-top: 40px; padding-top: 28px;
    display: grid; grid-template-columns: 52px 1fr; column-gap: 8px;
  }
  .diffs > li::before {
    content: counter(diff, decimal-leading-zero);
    font-family: var(--mono); font-size: 13px; color: var(--accent); font-weight: 700; padding-top: 7px;
  }
  .diffs > li:first-child { border-top: 0; margin-top: 28px; padding-top: 0; }
  .diffs > li:first-child::before { padding-top: 7px; }
  .diffs h2 { font-size: 24px; font-weight: 500; line-height: 1.25; letter-spacing: -0.01em; grid-column: 2; }
  .diffs p { grid-column: 2; margin-top: 12px; max-width: 66ch; color: var(--ink-soft); font-size: 16px; }
  .minifig { grid-column: 2; margin-top: 20px; }
  .minifig figcaption { margin-top: 10px; font-family: var(--mono); font-size: 11px; color: var(--ink-faint); max-width: 60ch; line-height: 1.6; }

  /* evidence ledgers */
  .ledger { border-collapse: collapse; width: 100%; max-width: 640px; background: var(--paper-raised); border: 1px solid var(--rule); }
  .ledger td { font-family: var(--mono); font-size: 12.5px; padding: 9px 14px; border-top: 1px solid var(--rule); vertical-align: baseline; }
  .ledger tr:first-child td { border-top: 0; }
  .ledger .k { color: var(--ink); white-space: nowrap; }
  .ledger .ok { color: var(--ok); font-weight: 600; white-space: nowrap; }
  .ledger .bad { color: var(--accent); font-weight: 700; white-space: nowrap; }
  .ledger .c { color: var(--ink-faint); width: 55%; }
  .roster .tier { font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); white-space: nowrap; }
  .roster .tier.hot { color: var(--accent); font-weight: 700; }

  /* split pane (SPA figure) */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 640px; }
  .pane { border: 1px solid var(--rule); background: var(--paper-raised); }
  .pane-label {
    font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-faint); padding: 8px 12px; border-bottom: 1px solid var(--rule);
  }
  .pane-body { padding: 14px 12px; min-height: 96px; }
  .pane-body code { font-family: var(--mono); font-size: 12.5px; color: var(--ink-faint); }
  .prose-demo { display: flex; flex-direction: column; gap: 8px; }
  .prose-demo .line { display: block; height: 7px; background: var(--rule); }
  .prose-demo .w100 { width: 100%; } .prose-demo .w95 { width: 95%; }
  .prose-demo .w90 { width: 90%; } .prose-demo .w75 { width: 75%; } .prose-demo .w60 { width: 60%; }

  /* stat bars */
  .stats { max-width: 640px; border: 1px solid var(--rule); background: var(--paper-raised); padding: 6px 14px; }
  .stat { display: grid; grid-template-columns: 120px 1fr 64px; gap: 14px; align-items: center; padding: 9px 0; }
  .stat + .stat { border-top: 1px solid var(--rule); }
  .stat-k { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
  .stat-bar { height: 7px; background: var(--rule); position: relative; overflow: hidden; }
  .stat-bar i {
    position: absolute; inset: 0 auto 0 0; width: 0; background: var(--accent);
    transition: width 0.9s var(--ease);
  }
  .stat-bar i.grown { width: var(--w); }
  .stat-v { font-family: var(--mono); font-size: 13px; font-weight: 700; text-align: right; }

  /* checks list */
  .checks { list-style: none; max-width: 640px; border: 1px solid var(--rule); background: var(--paper-raised); padding: 10px 14px; }
  .checks li {
    display: flex; gap: 10px; padding: 6px 0;
    font-family: var(--mono); font-size: 12.5px; color: var(--ink-soft); line-height: 1.6;
  }
  .checks .g { flex: 0 0 16px; text-align: center; font-weight: 700; }
  .g.pass { color: var(--ok); } .g.fail { color: var(--accent); }

  /* ---------- dimensions ---------- */
  .dims { list-style: none; margin-top: 30px; }
  .dims li {
    display: grid; grid-template-columns: 30px 220px 70px 1fr; gap: 14px; align-items: baseline;
    border-top: 1px solid var(--rule); padding: 13px 4px;
  }
  .dims li:last-child { border-bottom: 1px solid var(--rule); }
  .dimno { font-family: var(--mono); font-size: 11px; color: var(--ink-faint); }
  .dimname { font-size: 18px; }
  .dimweight { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); }
  .dimnote { font-size: 14.5px; color: var(--ink-soft); }

  /* ---------- method band ---------- */
  .band { margin-top: 88px; background: var(--ink); color: var(--paper); }
  .band-inner { max-width: 880px; margin: 0 auto; padding: 64px 28px 72px; }
  .band-rule { border-top: 2px solid var(--paper); position: relative; }
  .band-rule span {
    position: absolute; top: -11px; left: 0; background: var(--ink); padding-right: 14px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.75;
  }
  .band h2 { margin-top: 44px; font-size: clamp(30px, 5vw, 44px); font-weight: 500; line-height: 1.1; letter-spacing: -0.01em; }
  .band p { margin-top: 20px; max-width: 62ch; font-size: 16.5px; opacity: 0.85; }
  .band p em { font-style: italic; }
  .band .cta.inverted {
    margin-top: 34px; background: var(--paper); color: var(--ink); border-color: var(--paper);
  }
  .band .cta.inverted:hover { background: var(--accent); border-color: var(--accent); color: var(--paper); }

  /* ---------- colophon ---------- */
  .colophon {
    margin-top: 0; padding: 20px 0 60px;
    font-family: var(--mono); font-size: 11px; color: var(--ink-faint);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 760px) {
    .masthead-meta { display: none; }
    .hero { padding-top: 52px; }
    .diffs > li { grid-template-columns: 36px 1fr; }
    .split { grid-template-columns: 1fr; }
    .dims li { grid-template-columns: 24px 1fr 60px; }
    .dimnote { grid-column: 2 / 4; }
    .stat { grid-template-columns: 96px 1fr 56px; }
    .ledger .c { display: none; }
    .ledger td { white-space: normal; }
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .stat-bar i { transition: none; }
  }
</style>
</body>
</html>
