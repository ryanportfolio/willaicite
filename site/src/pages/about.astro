---
import Base, { UPDATED_ISO } from '../layouts/Base.astro';

const TITLE = 'About · willaicite';
const DESCRIPTION =
  'What willaicite is and how the audit works: a free, deterministic, evidence-based score of whether AI answer engines can retrieve, extract and cite a page. No LLM calls, no account, no trackers.';

const dims = [
  { name: 'AI crawler access', weight: 3, asks: 'Can retrieval crawlers fetch the page, and does a WAF treat them differently' },
  { name: 'Renderability', weight: 3, asks: 'Is the content readable without executing JavaScript' },
  { name: 'Answer-readiness', weight: 3, asks: 'Can an engine lift a definition, a heading, an answer block whole' },
  { name: 'Topical focus & metadata', weight: 3, asks: 'Do title, heading, description and body present one topic a retriever can match' },
  { name: 'Evidence density', weight: 2, asks: 'Does the page carry statistics, quotations and cited sources for engines to quote once it is retrieved' },
  { name: 'Structured data', weight: 2, asks: 'Does JSON-LD tell engines who wrote what, and when' },
  { name: 'Freshness', weight: 3, asks: 'Is there a machine-readable date signal from the last 90 days' },
  { name: 'Entity & E-E-A-T', weight: 2, asks: 'Can the author and organization behind the page be identified' },
];

const faqs = [
  {
    q: 'Is willaicite free?',
    a: 'Yes. Audits are free, require no account and set no cookies. Rate limiting keeps the load light: a visitor gets a batch of audits every ten minutes rather than an unlimited firehose.',
  },
  {
    q: 'Why does the audit stop at ten requests?',
    a: 'Courtesy to the site being audited. Ten requests are enough to score all eight dimensions (the page twice, robots.txt, the sitemap, an about page, the favicon and llms.txt), and a small fixed cap means an audit can never hammer the site it is inspecting. The audit honors robots.txt while it works.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'AboutPage',
      '@id': 'https://willaicite.com/about#page',
      name: 'About willaicite',
      url: 'https://willaicite.com/about',
      description: DESCRIPTION,
      dateModified: UPDATED_ISO,
      about: { '@id': 'https://willaicite.com/#org' },
    },
    {
      '@type': 'TechArticle',
      '@id': 'https://willaicite.com/about#article',
      headline: 'About willaicite: how the deterministic GEO audit works',
      description: DESCRIPTION,
      author: { '@id': 'https://willaicite.com/#ryan' },
      publisher: { '@id': 'https://willaicite.com/#org' },
      datePublished: '2026-07-17',
      dateModified: UPDATED_ISO,
      mainEntityOfPage: 'https://willaicite.com/about',
    },
    {
      '@type': 'Organization',
      '@id': 'https://willaicite.com/#org',
      name: 'willaicite',
      url: 'https://willaicite.com/',
      logo: 'https://willaicite.com/favicon.svg',
    },
    {
      '@type': 'Person',
      '@id': 'https://willaicite.com/#ryan',
      name: 'Ryan',
      url: 'https://github.com/ryanportfolio',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://willaicite.com/about#faq',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://willaicite.com/about#crumbs',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'willaicite', item: 'https://willaicite.com/' },
        { '@type': 'ListItem', position: 2, name: 'About', item: 'https://willaicite.com/about' },
      ],
    },
  ],
};
---
<Base title={TITLE} description={DESCRIPTION} canonical="https://willaicite.com/about" schema={schema}>

<main>
  <div class="sheet">
    <article class="aboutpage">
      <h1>About willaicite</h1>

      <p class="lede">
        willaicite is a free audit that scores how ready a web page is to be retrieved and
        cited by AI answer engines: ChatGPT, Perplexity, Google AI Overviews and Claude.
      </p>

      <div class="report-rule"><h2 class="rulelabel">How does the audit work?</h2></div>
      <p>
        An audit makes at most ten polite requests to the target site, honoring robots.txt
        throughout:
      </p>
      <ul class="fetches">
        <li>the page itself, fetched twice: once with a normal browser user agent, once with an AI crawler&rsquo;s, to expose WAF-level bot blocking</li>
        <li>robots.txt, checked against the full roster of AI retrieval and training crawlers</li>
        <li>the sitemap, an about page, the favicon and llms.txt</li>
      </ul>
      <p>
        The scoring is deterministic. There are no LLM calls and no sampling; every point is
        tied to observable evidence (an HTTP status, a robots.txt rule, a byte count of
        extractable text). When a check cannot run, the report marks it
        &ldquo;could not verify&rdquo; and leaves it out of the weighted score.
      </p>
      <p>
        Even the verdict line is deterministic, drawn from fixed score bands: a site in the
        fifties reads &ldquo;Needs work: real gaps are limiting how AI engines retrieve and
        cite this site&rdquo; while a clean run reads &ldquo;Excellent: well positioned to be
        retrieved and cited by AI answer engines&rdquo;.
      </p>

      <div class="report-rule"><h2 class="rulelabel">What do the eight dimensions measure?</h2></div>
      <table class="dims">
        <thead><tr><th>dimension</th><th>weight</th><th>question it answers</th></tr></thead>
        <tbody>
          {dims.map((d) => (
            <tr>
              <td class="dname">{d.name}</td>
              <td class="num">{d.weight}</td>
              <td class="asks">{d.asks}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="report-rule"><h2 class="rulelabel">What evidence backs the scoring?</h2></div>
      <p>
        The dimension weights and recommendations track the empirical GEO literature, weighted
        toward controlled and replicated results.
        <a class="body-link" href="https://arxiv.org/abs/2311.09735">Aggarwal et&nbsp;al., &ldquo;GEO: Generative Engine Optimization&rdquo;, KDD&nbsp;2024</a>
        measured that citing sources lifted generative visibility by 24.9%, adding statistics
        by 25.9%, and quotations by 27.8%, with the source already placed in the model&rsquo;s
        context. The 2025&ndash;2026 replications narrowed that claim:
        <a class="body-link" href="https://arxiv.org/abs/2605.25517">Vishwakarma et&nbsp;al., SIGIR&nbsp;2026</a>
        (252,000 controlled trials across six LLMs) found topical relevance and retrieval
        position dominate citation choice,
        <a class="body-link" href="https://arxiv.org/abs/2506.11097">C-SEO&nbsp;Bench, NeurIPS&nbsp;D&amp;B&nbsp;2025</a>
        found only 3 of 54 content-rewrite combinations significantly positive, and the
        <a class="body-link" href="https://arxiv.org/abs/2509.10762">GEO-16 field audit (2025)</a>
        found metadata, freshness and structured data the pillars most strongly associated
        with 1,702 real citations. That is why topical focus and freshness weigh high while
        evidence density weighs medium. The crawler roster tracks the engines&rsquo;
        own documentation
        (<a class="body-link" href="https://developers.openai.com/api/docs/bots">OpenAI</a>,
        <a class="body-link" href="https://support.claude.com/en/articles/8896518-does-anthropic-crawl-data-from-the-web-and-how-can-site-owners-block-the-crawler">Anthropic</a>,
        <a class="body-link" href="https://docs.perplexity.ai/guides/bots">Perplexity</a>),
        and the blocking landscape it grades against is measured, not assumed:
        <a class="body-link" href="https://reutersinstitute.politics.ox.ac.uk/how-many-news-websites-block-ai-crawlers">Fletcher, Reuters Institute, 2024</a>
        found &ldquo;48% of the most widely used news websites &hellip; were blocking
        OpenAI&rsquo;s crawlers&rdquo; by the end of 2023, while 24% blocked Google&rsquo;s AI
        crawler. Findings from single studies are presented as directional, never as guarantees.
      </p>

      <div class="report-rule"><h2 class="rulelabel">What happens to your data?</h2></div>
      <p>
        An audit touches only the site you ask it to audit, honoring robots.txt.
        There are no trackers, no analytics scripts and no external resources on these pages.
        Questions and corrections are welcome: <a class="body-link" href="mailto:hello@willaicite.com">hello@willaicite.com</a>.
      </p>

      <div class="report-rule"><h2 class="rulelabel">About FAQ</h2></div>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>

      <p class="backlink"><a class="cta" href="/audit">Audit your site</a></p>
    </article>
  </div>
</main>

<style is:global>
  .aboutpage { padding-top: 64px; }
  .aboutpage h1 { font-size: clamp(32px, 5vw, 46px); font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; }
  .aboutpage .lede { margin-top: 20px; max-width: 62ch; font-size: 18px; color: var(--ink-soft); }
  .aboutpage .report-rule { margin-top: 56px; }
  .aboutpage p { margin-top: 28px; max-width: 66ch; color: var(--ink-soft); }
  .aboutpage .report-rule + p { margin-top: 34px; }
  .aboutpage .fetches { margin: 16px 0 0 22px; max-width: 66ch; color: var(--ink-soft); }
  .aboutpage .fetches li { margin-top: 10px; font-size: 16px; }
  .aboutpage table.dims {
    border-collapse: collapse; width: 100%; margin-top: 24px;
    background: var(--paper-raised); border: 1px solid var(--rule);
  }
  .aboutpage .dims th {
    font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 400; text-align: left; padding: 10px 14px;
    border-bottom: 1px solid var(--rule);
  }
  .aboutpage .dims td { padding: 9px 14px; border-top: 1px solid var(--rule); vertical-align: top; }
  .aboutpage .dims tr:first-child td { border-top: 0; }
  .aboutpage .dims .dname { font-size: 15.5px; white-space: nowrap; }
  .aboutpage .dims .num { font-family: var(--mono); font-size: 14px; font-weight: 600; text-align: center; }
  .aboutpage .dims .asks { font-size: 15px; color: var(--ink-soft); }
  .aboutpage .faq { margin-top: 10px; }
  .aboutpage .faq-item { border-top: 1px solid var(--rule); margin-top: 24px; padding-top: 20px; }
  .aboutpage .faq-item:first-child { border-top: 0; margin-top: 22px; }
  .aboutpage .faq-item h3 { font-size: 20px; font-weight: 500; line-height: 1.3; letter-spacing: -0.01em; }
  .aboutpage .faq-item p { margin-top: 10px; max-width: 66ch; color: var(--ink-soft); font-size: 16px; }
  .aboutpage .backlink { margin-top: 48px; padding-bottom: 24px; }
</style>
</Base>
